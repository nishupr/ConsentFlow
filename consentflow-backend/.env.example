# ── ConsentFlow environment variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# ── Mistral AI ────────────────────────────────────────────────────────────────
# Get a key at: https://console.mistral.ai/api-keys/
# MISTRAL_API_KEY=your_mistral_key
# MISTRAL_MODEL=mistral-small-latest

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=consentflow
POSTGRES_USER=consentflow
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=           # uncomment if your Redis requires auth

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development         # development | production
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# ── Cache ─────────────────────────────────────────────────────────────────────
CONSENT_CACHE_TTL=60        # seconds

# ── Kafka ─────────────────────────────────────────────────────────────────────
# When running outside Docker (local dev), use the externally-exposed port 29092.
# Inside Docker Compose the app container uses kafka:9092 (set automatically).
KAFKA_BROKER_URL=localhost:29092
# Topic where consent-revocation events are published.
KAFKA_TOPIC_REVOKE=consent.revoked

# ── Gate 05: Policy Auditor (Ollama local LLM) ────────────────────────────────
# Ollama OpenAI-compatible endpoint (running on host machine).
# NOTE: If FastAPI runs inside Docker, change to http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma2:2b

# ── Anthropic Claude (Gate 05 Policy Auditor) ─────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...